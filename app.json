
{
  "expo": {
    "name": "BioLoop",
    "slug": "BioLoop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-tyg.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/app-icon-tyg.png",
      "resizeMode": "contain",
      "backgroundColor": "#0066FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bioloop.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSHealthShareUsageDescription": "BioLoop analyzes your heart rate, HRV, sleep, and workout data to calculate your Performance Index and biological age. Your data never leaves your device.",
        "NSHealthUpdateUsageDescription": "BioLoop needs to read your health data to provide personalized insights."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-tyg.png",
        "backgroundColor": "#0066FF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.bioloop.app"
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser"
    ],
    "scheme": "bioloop",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
